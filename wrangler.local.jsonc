{
  "name": "wiggle-web-local",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "wiggle-web-local",
      "database_id": "00000000-0000-4000-8000-000000000000"
    }
  ],
  "r2_buckets": [
    { "binding": "ARTWORKS", "bucket_name": "wiggle-web-local-artworks" }
  ]
}
